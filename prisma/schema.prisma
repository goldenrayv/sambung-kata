generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Word {
  id       String  @id @default(cuid())
  word     String  @unique
  isActive Boolean @default(true)
}
